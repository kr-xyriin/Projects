# .env.example — Copy to .env and fill in your values
# EcoLens Environment Configuration

# Email Configuration (for pollution alerts)
SENDER_EMAIL=your_email@gmail.com
SENDER_PASSWORD=your_gmail_app_password_here   # 16-char App Password, NOT your real password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# Default Authority (can be overridden in UI)
AUTHORITY_EMAIL=officer@municipality.gov.in
AUTHORITY_NAME=Sanitation Officer
AREA_NAME=Your Area Name
AREA_TYPE=urban   # urban / semi_urban / rural / industrial
